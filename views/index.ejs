<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">
<title>Goiás de Fato News</title>

<link rel="stylesheet" href="/css/style.css">

<style>

.layout{
display:grid;
grid-template-columns:3fr 1fr;
gap:30px;
}

.sidebar{
background:white;
padding:20px;
border-radius:8px;
box-shadow:0 2px 8px rgba(0,0,0,0.1);
height:fit-content;
}

.sidebar h3{
margin-bottom:15px;
}

.sidebar a{
display:block;
margin-bottom:10px;
color:#002776;
text-decoration:none;
font-weight:bold;
}

.sidebar a:hover{
text-decoration:underline;
}

</style>

</head>

<body>

<header>

<div class="topo">

<div class="logo">
<img src="/img/logo.png" class="logo-img">
</div>

<div class="busca">

<form action="/buscar">

<input type="text" name="q" placeholder="Buscar notícia...">

</form>

</div>

</div>

</header>

<nav>

<ul>

<li><a href="/">Início</a></li>
<li><a href="/categoria/Politica">Política</a></li>
<li><a href="/categoria/Goias">Goiás</a></li>
<li><a href="/categoria/Brasil">Brasil</a></li>
<li><a href="/categoria/Economia">Economia</a></li>
<li><a href="/categoria/Opiniao">Opinião</a></li>

</ul>

</nav>

<div class="container">

<div class="layout">

<div>

<!-- NOTICIA DESTAQUE -->

<% if(noticias.length > 0){ %>

<div class="destaque">

<% if(noticias[0].imagem){ %>
<img src="/img/<%= noticias[0].imagem %>">
<% } %>

<p style="color:#0b8a2a;font-weight:bold">
<%= noticias[0].categoria %>
</p>

<h2>
<a href="/noticia/<%= noticias[0].id %>">
<%= noticias[0].titulo %>
</a>
</h2>

<p>
<%= noticias[0].conteudo.substring(0,200) %>...
</p>

</div>

<% } %>

<!-- 3 NOTICIAS PRINCIPAIS -->

<div class="principais">

<% noticias.slice(1,4).forEach(function(n){ %>

<div class="card">

<p style="color:#0b8a2a;font-weight:bold">
<%= n.categoria %>
</p>

<% if(n.imagem){ %>
<img src="/img/<%= n.imagem %>">
<% } %>

<h3>
<a href="/noticia/<%= n.id %>">
<%= n.titulo %>
</a>
</h3>

</div>

<% }) %>

</div>

<!-- OUTRAS NOTICIAS -->

<section class="grid-noticias">

<% noticias.slice(4).forEach(function(n){ %>

<div class="card">

<p style="color:#0b8a2a;font-weight:bold">
<%= n.categoria %>
</p>

<% if(n.imagem){ %>
<img src="/img/<%= n.imagem %>">
<% } %>

<h3>
<a href="/noticia/<%= n.id %>">
<%= n.titulo %>
</a>
</h3>

<p>
<%= n.conteudo.substring(0,120) %>...
</p>

</div>

<% }) %>

</section>

</div>

<!-- SIDEBAR MAIS LIDAS -->

<div class="sidebar">

<h3>🔥 Mais lidas</h3>

<% if(maisLidas){ %>

<% maisLidas.forEach(function(n){ %>

<a href="/noticia/<%= n.id %>">

<%= n.titulo %>

</a>

<% }) %>

<% } %>

</div>

</div>

</div>

<footer>

<p>© 2026 Goiás de Fato News</p>

</footer>

</body>

</html>